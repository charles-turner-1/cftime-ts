{
  "name": "cftime-ts",
  "version": "0.1.0",
  "description": "TypeScript implementation of CF-convention calendar datetimes (a port of Python cftime): num2date, date2num, and nine CF calendars.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/charles-turner-1/cftime-ts.git"
  },
  "bugs": {
    "url": "https://github.com/charles-turner-1/cftime-ts/issues"
  },
  "homepage": "https://github.com/charles-turner-1/cftime-ts#readme",
  "keywords": [
    "cftime",
    "netcdf",
    "cf-conventions",
    "calendar",
    "datetime",
    "num2date",
    "date2num"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "typecheck": "tsc --noEmit",
    "check:package": "node ./scripts/check-package.mjs",
    "lint": "prettier --check .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "@vitest/coverage-v8": "^2.1.9",
    "prettier": "^3.9.4",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
